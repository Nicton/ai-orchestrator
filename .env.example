# App
APP_PORT=4321
DATABASE_URL=postgresql://orchestrator:orchestrator@db:5432/orchestrator

# OpenAI
# Option A (simple):
OPENAI_API_KEY=replace_me
# Option B (recommended on servers): mount key file into container + set path:
# OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Worker
WORKER_POLL_MS=2000
CALLBACK_TIMEOUT_MS=10000
