# App
APP_PORT=4321
DATABASE_URL=postgresql://orchestrator:orchestrator@db:5432/orchestrator

# OpenAI
# Option A (simple):
OPENAI_API_KEY=replace_me
# Option B (recommended on servers): mount key file into container + set path:
# OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Worker
WORKER_POLL_MS=2000
CALLBACK_TIMEOUT_MS=10000

# Knowledge Assistant: default admin (seeded on first startup if missing)
# Domain does not matter — any email containing ADMIN_EMAIL_MATCH is an admin.
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=change-me
# Any account whose email contains this substring is auto-promoted to admin
# (at seeding, at creation, and at login). Set empty to disable.
ADMIN_EMAIL_MATCH=asmalouski

# Claude model used for grounded answers (via Claude Code CLI)
# CLAUDE_MODEL=claude-sonnet-4-6
# Target answer-generation model for Searchify (master spec: "Fable 5").
# The deployment must alias this name to a real backend model.
ANSWER_MODEL=fable-5
# Set MOCK_LLM=1 to produce grounded answers + mock transcripts without network.
# MOCK_LLM=1

# Speech-to-text (Whisper). When OPENAI_API_KEY is set, voice questions are
# transcribed server-side via the Whisper API. Browser speech is not used.
# OPENAI_API_KEY=replace_me
# STT_BASE_URL=https://api.openai.com/v1
# STT_MODEL=whisper-1

# Bugs section → Jira (file defects). REST v2 with an API token (email:token Basic auth).
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=replace_me
JIRA_DEFAULT_PROJECT=TMS

# Google OAuth (Sign in with Google) — see auth.ts
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_REDIRECT_URI=https://your-host/auth/google/callback
# GOOGLE_ALLOWED_DOMAIN=shiptify.com
