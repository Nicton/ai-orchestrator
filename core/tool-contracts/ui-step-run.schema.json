{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datamola.example/schemas/ui-step-run.schema.json",
  "title": "UI Step Run",
  "type": "object",
  "required": ["runId", "step", "attempts", "success", "artifacts"],
  "properties": {
    "runId": { "type": "string" },
    "startedAt": { "type": "string" },
    "finishedAt": { "type": "string" },
    "step": { "$ref": "./ui-step.schema.json" },
    "attempts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["attempt", "chosenLocator", "postconditionVerdict"],
        "properties": {
          "attempt": { "type": "integer", "minimum": 1 },
          "chosenLocator": {
            "type": "object",
            "required": ["strategy", "value"],
            "properties": {
              "strategy": { "type": "string" },
              "value": { "type": "string" }
            },
            "additionalProperties": true
          },
          "candidates": {
            "type": "array",
            "items": { "type": "object" }
          },
          "preSnapshot": { "type": "string" },
          "postSnapshot": { "type": "string" },
          "postconditionVerdict": {
            "type": "object",
            "required": ["ok"],
            "properties": {
              "ok": { "type": "boolean" },
              "matched_oracle": { "type": "string" },
              "details": { "type": "string" }
            },
            "additionalProperties": true
          },
          "failure": {
            "type": ["object", "null"],
            "properties": {
              "class": { "type": "string" },
              "reason": { "type": "string" },
              "evidence": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "success": { "type": "boolean" },
    "artifacts": {
      "type": "object",
      "properties": {
        "dir": { "type": "string" },
        "summary": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
