{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datamola.example/schemas/ui-step.schema.json",
  "title": "UI Action Step",
  "type": "object",
  "required": ["stepId", "intent", "targetSemantic", "preconditions", "postconditions"],
  "properties": {
    "stepId": { "type": "string" },
    "intent": { "type": "string" },
    "targetSemantic": {
      "type": "object",
      "required": ["role"],
      "properties": {
        "role": { "type": "string" },
        "nameLike": { "type": "array", "items": { "type": "string" } },
        "testId": { "type": "string" }
      },
      "additionalProperties": true
    },
    "scope": {
      "type": "object",
      "properties": {
        "activeModal": { "type": "boolean" },
        "nearestHeading": { "type": "string" },
        "containerTestId": { "type": "string" }
      },
      "additionalProperties": true
    },
    "preconditions": { "type": "array", "items": { "type": "string" } },
    "postconditions": { "type": "array", "items": { "type": "string" } },
    "alternatives": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
