model QaTestRunItem {
  id                    String    @id @default(cuid())
  globalId              String
  projectId             String
  testRunId             String
  sourceType            String
  sourceId              String
  sourceVersionNumber   Int?
  titleSnapshot         String?
  stepsSnapshot         Json?
  status                String    @default("NotRun")
