generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

// --- Workflow Orchestrator v1 (TZ 2026-04-28) ---
// NOTE: prefixed with Wf* to avoid conflicts with legacy Task/PipelineRun tables.

enum WfTaskStatus {
  NEW
  ANALYZING
  NEEDS_CLARIFICATION
  WAITING_FOR_HUMAN
  CLARIFICATION_RECEIVED
  READY_FOR_EXECUTION
  IN_PROGRESS
  COMMITTED
  READY_FOR_REVIEW
  BLOCKED
  ESCALATED
  DONE
  CANCELLED
}

enum WfQuestionStatus {
  OPEN
  ANSWERED
  IGNORED
  CANCELLED
  SUPERSEDED
}

enum WfEventType {
  TASK_CREATED
  ANALYSIS_STARTED
  ANALYSIS_COMPLETED
  QUESTION_CREATED
  QUESTION_SENT
  ANSWER_RECEIVED
  STATUS_CHANGED
  PING_SENT
  ESCALATION_SENT
  EXECUTION_STARTED
  COMMIT_CREATED
  PR_CREATED
  TASK_DONE
  TASK_CANCELLED
}

enum WfJobType {
  ANALYZE_TASK
  REANALYZE_TASK
  SEND_QUESTION
  SEND_REMINDER
  ESCALATE_TASK
  EXECUTE_TASK
  RUN_TESTS
  COMMIT_CHANGES
  CREATE_REVIEW_SUMMARY
  SYNC_EXTERNAL_STATUS
}

enum WfJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum RunStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum StageStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  SKIPPED
}

// --- Voice → Requirement Intake (Shiptify) ---

enum IntakeStatus {
  RECEIVED
  TRANSCRIBED
  QUESTIONNAIRE
  DRAFT_READY
  CREATED_IN_JIRA
  NEEDS_INFO
  ERROR
}

enum IntakeInputKind {
  voice
  text
}

enum IntakeJobType {
  TRANSCRIBE
  GENERATE_QUESTIONNAIRE
  GENERATE_REQUIREMENT_CARD
  CREATE_JIRA_ISSUE
}

enum IntakeJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model Task {
  id               String     @id @default(cuid())
  title            String?
  role             String
  prompt           String
  callbackUrl      String?
  status           TaskStatus @default(PENDING)
  resultText       String?
  errorMessage     String?
  model            String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  startedAt        DateTime?
  finishedAt       DateTime?

  @@index([status, createdAt])
  @@index([createdAt])
}

model PipelineRun {
  id         String    @id @default(cuid())
  title      String?
  pipelineId String
  inputText  String
  status     RunStatus @default(PENDING)

  // Optional external correlation IDs (e.g., YouTrack issue)
  externalRef String?

  // Optional attribution (who created the run)
  createdBy String?

  resultText   String?
  errorMessage String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  stages    StageRun[]
  artifacts Artifact[]

  @@index([status, createdAt])
  @@index([pipelineId, createdAt])
}

model StageRun {
  id          String      @id @default(cuid())
  runId       String
  stageId     String
  stageName   String
  roleOrSkill String
  status      StageStatus @default(PENDING)
  dependsOn   String[]

  promptText   String?
  resultText   String?
  errorMessage String?

  model            String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  run       PipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  artifacts Artifact[]

  @@index([runId, stageId])
  @@index([status, createdAt])
}

model Artifact {
  id         String  @id @default(cuid())
  runId      String
  stageRunId String?

  kind        String
  name        String?
  contentType String  @default("text/plain")
  text        String?
  url         String?

  createdAt DateTime @default(now())

  run      PipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  stageRun StageRun?   @relation(fields: [stageRunId], references: [id], onDelete: Cascade)

  @@index([runId, kind])
  @@index([stageRunId, kind])
}

// --- Workflow Orchestrator tables ---
model WfUser {
  id              String   @id @default(cuid())
  externalUserId  String?
  name            String
  email           String?
  role            String?
  messengerHandle String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reportedTasks WfTask[] @relation("wf_reporter")
  assignedTasks WfTask[] @relation("wf_assignee")
}

model WfProject {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  repositories WfRepository[]
  tasks        WfTask[]

  @@unique([name])
}

model WfRepository {
  id            String   @id @default(cuid())
  projectId     String
  url           String
  defaultBranch String   @default("main")
  accessType    String? // ssh|https|token|...
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project WfProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   WfTask[]

  @@unique([projectId, url])
  @@index([projectId])
}

model WfTask {
  id String @id @default(cuid())

  externalSource String?
  externalTaskId String?

  title       String
  description String?
  taskType    String?
  priority    String?

  status WfTaskStatus @default(NEW)

  projectId    String?
  repositoryId String?

  reporterId String?
  assigneeId String?

  deadlineAt DateTime?

  nextPingAt DateTime?
  pingCount  Int       @default(0)

  blockedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project    WfProject?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  repository WfRepository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  reporter WfUser? @relation("wf_reporter", fields: [reporterId], references: [id], onDelete: SetNull)
  assignee WfUser? @relation("wf_assignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  events     WfTaskEvent[]
  questions  WfTaskQuestion[]
  answers    WfTaskAnswer[]
  jobs       WfJob[]
  aiRuns     WfAiRun[]
  gitChanges WfGitChange[]

  @@index([status, createdAt])
  @@index([externalSource, externalTaskId])
}

model WfTaskEvent {
  id        String      @id @default(cuid())
  taskId    String
  eventType WfEventType
  actorType String? // human|ai|system|integration
  actorId   String?
  payload   Json?
  createdAt DateTime    @default(now())

  task WfTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([eventType, createdAt])
}

model WfTaskQuestion {
  id           String           @id @default(cuid())
  taskId       String
  questionText String
  reason       String?
  targetUserId String?
  targetRole   String?
  status       WfQuestionStatus @default(OPEN)
  priority     String?
  createdAt    DateTime         @default(now())
  answeredAt   DateTime?

  task    WfTask         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  answers WfTaskAnswer[]

  @@index([taskId, status])
}

model WfTaskAnswer {
  id         String   @id @default(cuid())
  taskId     String
  questionId String?
  authorId   String?
  answerText String
  source     String?
  createdAt  DateTime @default(now())

  task     WfTask          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  question WfTaskQuestion? @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
}

model WfJob {
  id           String      @id @default(cuid())
  taskId       String
  type         WfJobType
  status       WfJobStatus @default(PENDING)
  payload      Json?
  attempts     Int         @default(0)
  runAfter     DateTime? // schedule / reminder
  errorMessage String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  startedAt    DateTime?
  finishedAt   DateTime?

  task WfTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([type, status])
  @@index([runAfter])
}

model WfAiRun {
  id            String    @id @default(cuid())
  taskId        String
  pipelineId    String?
  modelProvider String?
  modelName     String?
  status        String
  inputSummary  String?
  outputSummary String?
  tokensInput   Int?
  tokensOutput  Int?
  costEstimate  Float?
  startedAt     DateTime? @default(now())
  finishedAt    DateTime?
  errorMessage  String?

  task WfTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, startedAt])
}

model WfGitChange {
  id             String   @id @default(cuid())
  taskId         String
  repositoryId   String?
  branchName     String
  commitHash     String?
  pullRequestUrl String?
  status         String?
  createdAt      DateTime @default(now())

  task WfTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model Intake {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId    String?
  customerName  String
  customerEmail String?

  inputKind        IntakeInputKind
  inputText        String?
  audioMime        String?
  audioDurationSec Float?
  audioPath        String? // local storage path under ./data (docker volume)

  status       IntakeStatus @default(RECEIVED)
  errorMessage String?

  locale String?
  source String?

  transcript      Transcript?
  questionnaire   QuestionnaireAnswerSet?
  requirementCard RequirementCard?
  jiraLink        JiraIssueLink?

  events IntakeEvent[]
  jobs   IntakeJob[]

  @@index([status, createdAt])
}

model Transcript {
  id        String   @id @default(cuid())
  intakeId  String   @unique
  createdAt DateTime @default(now())

  text       String
  confidence Float?
  language   String?
  segments   Json?

  intake Intake @relation(fields: [intakeId], references: [id], onDelete: Cascade)
}

model QuestionnaireAnswerSet {
  id        String   @id @default(cuid())
  intakeId  String   @unique
  createdAt DateTime @default(now())

  answers Json

  intake Intake @relation(fields: [intakeId], references: [id], onDelete: Cascade)
}

model RequirementCard {
  id        String   @id @default(cuid())
  intakeId  String   @unique
  createdAt DateTime @default(now())

  title              String
  summary            String
  userStory          String
  scope              Json
  affectedArea       Json
  acceptanceCriteria Json
  openQuestions      Json
  attachments        Json

  markdown String

  intake Intake @relation(fields: [intakeId], references: [id], onDelete: Cascade)
}

model JiraIssueLink {
  id        String   @id @default(cuid())
  intakeId  String   @unique
  createdAt DateTime @default(now())

  issueId  String?
  issueKey String?
  issueUrl String?

  // used for idempotency/search markers
  intakeMarker String @unique

  intake Intake @relation(fields: [intakeId], references: [id], onDelete: Cascade)
}

model IntakeEvent {
  id        String   @id @default(cuid())
  intakeId  String
  createdAt DateTime @default(now())

  type    String
  payload Json?

  intake Intake @relation(fields: [intakeId], references: [id], onDelete: Cascade)

  @@index([intakeId, createdAt])
}

model IntakeJob {
  id       String @id @default(cuid())
  intakeId String

  type    IntakeJobType
  status  IntakeJobStatus @default(PENDING)
  payload Json?

  attempts Int       @default(0)
  runAfter DateTime?
  lockedAt DateTime?

  errorMessage String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  intake Intake @relation(fields: [intakeId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([type, status])
  @@index([runAfter])
  @@index([intakeId, status])
}

model KnowledgeQuery {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  userLabel          String?
  channel            String?
  question           String
  normalizedQuestion String?
  answer             String
  answerMode         String?
  llmLog             String?  // лог запроса к LLM (движок, модель, исход) — показывается в Истории
  intent             String?
  confidence         Float?
  latencyMs          Int?
  sourceCount        Int      @default(0)
  rating             Int?
  ratedAt            DateTime?
  inputMode          String?  // text|voice
  sources            Json?

  userId String?
  user   AppUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  feedbacks   KnowledgeFeedback[]
  corrections KnowledgeCorrection[]

  @@index([createdAt])
  @@index([intent, createdAt])
  @@index([normalizedQuestion])
  @@index([userId, createdAt])
}

// --- Auth & accounts (email/password login, roles user|admin) ---

model AppUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  role         String    @default("user") // user|admin
  passwordHash String
  passwordSalt String
  isActive     Boolean   @default(true)
  mustReset    Boolean   @default(false)
  inviteToken  String?   @unique
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions    AppSession[]
  queries     KnowledgeQuery[]
  feedbacks   KnowledgeFeedback[]
  corrections KnowledgeCorrection[]
  ideas       Idea[]

  @@index([role])
}

// Идеи к улучшению (Improvement ideas). Пользователь предлагает; админ
// рассматривает/реализует. Статусы: PENDING|APPROVED|REJECTED|IN_PROGRESS|APPLIED|FAILED.
model Idea {
  id           String   @id @default(cuid())
  userId       String
  userLabel    String?
  title        String
  body         String
  status       String   @default("PENDING")
  log          String?  // вывод агента / результат реализации
  commitSha    String?
  reviewedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// Снапшот состояния качества (Quality Coverage Analytics) — для анализа динамики.
model QualitySnapshot {
  id        String   @id @default(cuid())
  label     String?
  data      Json     // { kpi, modules:[{name,size,score,...}] }
  createdAt DateTime @default(now())
  createdBy String?

  @@index([createdAt])
}

model AppSession {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
  userAgent String?

  @@index([userId])
  @@index([expiresAt])
}

model KnowledgeFeedback {
  id        String   @id @default(cuid())
  queryId   String
  userId    String?
  kind      String   @default("text") // text|voice
  text      String
  rating    Int?
  createdAt DateTime @default(now())

  query KnowledgeQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  user  AppUser?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([queryId, createdAt])
  @@index([createdAt])
}

model KnowledgeCorrection {
  id        String   @id @default(cuid())
  queryId   String
  userId    String?
  kind      String   @default("text") // text|voice

  // Structured correction capture (master spec §8):
  text       String // free-form correction (what was wrong + how it should be)
  whatWrong  String? // what specifically was wrong in the answer
  corrected  String? // the corrected knowledge ("how it should be")
  topic      String? // topic / entity / process the correction relates to

  // Knowledge update workflow: a correction is reviewed and applied so that
  // later answers are built on the corrected truth (not left in logs).
  status         String    @default("OPEN") // OPEN|APPLIED|REJECTED
  appliedAt      DateTime?
  appliedEntryId String? // resulting KnowledgeEntry id once applied
  reviewedById   String?

  createdAt DateTime @default(now())

  query KnowledgeQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  user  AppUser?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([queryId, createdAt])
  @@index([status, createdAt])
}

// --- Operational knowledge store (DB-backed, master spec §9) ---
// First-class, controllable knowledge unit. Indexed for retrieval alongside
// files. Applied corrections and curated facts live here so answers can be
// updated without editing markdown.
model KnowledgeEntry {
  id         String   @id @default(cuid())
  title      String
  body       String
  language   String? // ru|en|...
  sourceType String   @default("operational") // operational|correction|manual|confluence|jira|web
  sourceUrl  String?
  status     String   @default("APPROVED") // DRAFT|APPROVED|DEPRECATED
  origin     String? // correction|manual|import
  topic      String?
  weight     Float    @default(1.5)

  correctionId String?
  createdById  String?

  entityId String?
  entity   KnowledgeEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, updatedAt])
  @@index([topic])
  @@index([entityId])
}

// --- Graph knowledge model (master spec §10/§11) ---
model KnowledgeEntity {
  id        String   @id @default(cuid())
  name      String
  type      String // feature|module|process|api|requirement|role|document|integration|entity
  summary   String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries       KnowledgeEntry[]
  relationsFrom KnowledgeRelation[] @relation("relFrom")
  relationsTo   KnowledgeRelation[] @relation("relTo")

  @@unique([type, name])
  @@index([type])
}

model KnowledgeRelation {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  type      String // uses|depends_on|part_of|documented_by|covered_by|exposes|corrects|relates_to
  metadata  Json?
  createdAt DateTime @default(now())

  from KnowledgeEntity @relation("relFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   KnowledgeEntity @relation("relTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, type])
  @@index([fromId])
  @@index([toId])
}

model KnowledgeGap {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  topic         String   @unique
  title         String
  reason        String?
  status        String   @default("OPEN")
  occurrences   Int      @default(1)
  lastQuestion  String?
  confidenceAvg Float?
  metadata      Json?

  @@index([status, updatedAt])
  @@index([occurrences, updatedAt])
}
